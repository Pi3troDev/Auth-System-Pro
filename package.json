{
  "name": "auth-system-pro",
  "version": "1.0.0",
  "description": "Clean Architecture Authentication System with Node.js, TypeScript, React and Prisma",
  "private": true,
  "workspaces": [
    "packages/backend",
    "packages/frontend",
    "packages/shared"
  ],
  "scripts": {
    "dev:backend": "npm -w @auth-system/backend run dev",
    "dev:frontend": "npm -w @auth-system/frontend run dev",
    "dev": "npm run dev:backend & npm run dev:frontend",
    "build": "npm run build --workspaces",
    "build:backend": "npm -w @auth-system/backend run build",
    "build:frontend": "npm -w @auth-system/frontend run build",
    "start": "npm -w @auth-system/backend run start",
    "types": "npm run build -w @auth-system/shared",
    "prisma:migrate": "npm -w @auth-system/backend run prisma:migrate",
    "prisma:studio": "npm -w @auth-system/backend run prisma:studio"
  },
  "keywords": [
    "clean-architecture",
    "nodejs",
    "typescript",
    "react",
    "prisma"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "terser": "^5.46.1"
  }
}
